# VAPT Secure WordPress Plugin - Environment Configuration
# Copy this file to .env and customize for your environment

# ============================================================================
# DEVELOPMENT ENVIRONMENT
# ============================================================================

# WordPress Database Configuration
DB_HOST=localhost
DB_NAME=vaptsecure_dev
DB_USER=vaptsecure_user
DB_PASSWORD=secure_password_here
DB_CHARSET=utf8mb4
DB_COLLATE=utf8mb4_unicode_ci
DB_PREFIX=wp_

# WordPress Site URL
WP_SITEURL=http://localhost:8080
WP_HOME=http://localhost:8080

# ============================================================================
# DEBUGGING
# ============================================================================

# Enable WordPress debug mode
WP_DEBUG=true
WP_DEBUG_LOG=true
WP_DEBUG_DISPLAY=false
SCRIPT_DEBUG=true

# Plugin-specific debug
VAPTSECURE_DEBUG=true
VAPTSECURE_LOG_LEVEL=debug  # Options: error, warning, info, debug

# ============================================================================
# PERFORMANCE
# ============================================================================

# Object caching (Redis/Memcached)
WP_CACHE=true
WP_REDIS_HOST=127.0.0.1
WP_REDIS_PORT=6379
WP_REDIS_DATABASE=0

# Memory limits
WP_MEMORY_LIMIT=512M
WP_MAX_MEMORY_LIMIT=512M

# ============================================================================
# SECURITY
# ============================================================================

# Force SSL (set to true in production)
FORCE_SSL_ADMIN=false

# Salts (generate unique values at https://api.wordpress.org/secret-key/1.1/salt/)
AUTH_KEY='put your unique phrase here'
SECURE_AUTH_KEY='put your unique phrase here'
LOGGED_IN_KEY='put your unique phrase here'
NONCE_KEY='put your unique phrase here'
AUTH_SALT='put your unique phrase here'
SECURE_AUTH_SALT='put your unique phrase here'
LOGGED_IN_SALT='put your unique phrase here'
NONCE_SALT='put your unique phrase here'

# ============================================================================
# VAPT SECURE PLUGIN SETTINGS
# ============================================================================

# Development mode disables certain safety checks
VAPTSECURE_DEV_MODE=true

# Disable enforcement globally (emergency kill switch)
VAPTSECURE_GLOBAL_ENFORCEMENT=true

# Default deployment profile
# Options: auto_detect, apache, nginx, iis, caddy, cloudflare
VAPTSECURE_DEPLOYMENT_PROFILE=auto_detect

# Schema file to use
VAPTSECURE_ACTIVE_SCHEMA=interface_schema_v2.0.json

# Pattern library version
VAPTSECURE_PATTERN_LIBRARY=enforcer_pattern_library_v2.0.json

# ============================================================================
# AI/ML INTEGRATION (Optional)
# ============================================================================

# OpenAI API Key for AI-powered feature generation
# OPENAI_API_KEY=sk-...

# AI Model to use
# VAPTSECURE_AI_MODEL=gpt-4

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

# Enable usage analytics
VAPTSECURE_ANALYTICS=false

# External logging service
# VAPTSECURE_LOG_ENDPOINT=https://logs.example.com/api/v1

# ============================================================================
# PRODUCTION OVERRIDES
# ============================================================================

# Uncomment these for production deployment:

# WP_DEBUG=false
# VAPTSECURE_DEBUG=false
# VAPTSECURE_DEV_MODE=false
# FORCE_SSL_ADMIN=true
# DISALLOW_FILE_EDIT=true
# DISALLOW_FILE_MODS=true
